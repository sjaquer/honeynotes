/**
 * HoneyNotes Firestore Security Rules
 * 
 * Data Structure:
 * - /letters/{letterId}: All letters (with title, customizable names)
 * - /users/{userId}: User profiles with email auth
 * - /partnerCodes/{code}: Partner invitation codes
 * - /tasks/{taskId}: Global task definitions
 * - /userEconomy/{userId}: User's currency and inventory
 * - /userTasks/{userId}: User's weekly task progress
 * - /promoCodes/{codeId}: Promotional codes for rewards
 *
 * Key Security:
 * - Letters: sender can create/delete, sender OR recipient can read, recipient can update (mark read)
 * - Users: owner can read/write, any signed-in user can read for partner linking
 * - Partner codes: owner can delete, authenticated users can read/create
 * - Tasks: public read, admin write only
 * - Economy: owner can read/write their own data
 * - User Tasks: owner can read/write their own progress
 * - Promo Codes: read/update for auth users, create/delete admin only
 * 
 * Partner Unlinking Flow:
 * - When user A deletes/regenerates their code, they can update user B's profile to clear partnerId
 * - This is allowed because user A needs to notify user B of the unlink
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isLetterParticipant() {
      return isSignedIn() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid
      );
    }

    // Check if this is a valid partner unlink operation
    // User can only clear partnerId/partnerName on their partner's profile
    function isValidPartnerUnlink() {
      let existingData = resource.data;
      
      // The current authenticated user must be the existing partnerId of the target user
      // This means the target user's partnerId points to us (we are their partner)
      return isSignedIn() && existingData.partnerId == request.auth.uid;
    }

    // Check if this is a valid partner link operation
    // User can set themselves as partnerId on someone who has a partnerCode
    function isValidPartnerLink() {
      let existingData = resource.data;
      
      // The target user must have a partnerCode (they shared it for linking)
      // and they must not already have a partner
      return isSignedIn()
        && existingData.partnerCode != null
        && (existingData.partnerId == null || !('partnerId' in existingData));
    }

    /**
     * Letters collection
     * /letters/{letterId}
     * 
     * Fields: id, senderId, recipientId, title?, content, config, 
     *         createdAt, status, isRead, senderName, recipientName
     */
    match /letters/{letterId} {
      // Anyone authenticated can create letters (must be the sender)
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      
      // Only sender or recipient can read
      allow read: if isLetterParticipant();
      
      // Only recipient can update (mark as read)
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      
      // Only sender can delete their letters
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    /**
     * User profiles
     * /users/{userId}
     * 
     * Fields: id, displayName, email, photoURL?, partnerCode?, partnerId?, 
     *         partnerName?, partnerUnlinkedAt?, createdAt, updatedAt
     */
    match /users/{userId} {
      // Any signed-in user can read (needed for partner linking)
      allow read: if isSignedIn();
      
      // Owner can always write to their own profile
      allow write: if isOwner(userId);
      
      // Partner can unlink by clearing partnerId/partnerName (for unlink notification)
      allow update: if isValidPartnerUnlink();
      
      // Allow partner linking - user can set themselves as partner on another user's profile
      allow update: if isValidPartnerLink();
    }

    /**
     * Partner invitation codes
     * /partnerCodes/{code}
     * 
     * Fields: userId, createdAt
     */
    match /partnerCodes/{code} {
      // Anyone signed in can read codes (for linking)
      allow read: if isSignedIn();
      
      // Anyone signed in can create a code
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Only the owner of the code can delete it
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // No updates allowed - delete and recreate instead
      allow update: if false;
    }

    /**
     * Global tasks (read-only for clients)
     * /tasks/{taskId}
     */
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if false; // Admin only via console
    }

    /**
     * User Economy - Currency and Inventory
     * /userEconomy/{userId}
     * 
     * Fields: polen, jaleaReal, inventory, lastAdWatch, adsWatchedToday, 
     *         totalPolenEarned, totalJaleaRealEarned, totalLettersSent, totalLettersRead, updatedAt
     */
    match /userEconomy/{userId} {
      // Only owner can read and write their economy data
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    /**
     * User Weekly Tasks Progress
     * /userTasks/{userId}
     * 
     * Fields: weekStart, tasks (array of { taskId, progress, completed, claimed })
     */
    match /userTasks/{userId} {
      // Only owner can read and write their task progress
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    /**
     * Promotional Codes
     * /promoCodes/{codeId}
     * 
     * Fields: polen, jaleaReal, maxUses, usedCount, usedBy[], expiresAt, createdAt, isActive
     */
    match /promoCodes/{codeId} {
      // Anyone authenticated can read promo codes (to redeem them)
      allow read: if isSignedIn();
      
      // Users can update to add themselves to usedBy and increment usedCount
      allow update: if isSignedIn();
      
      // Only admin can create/delete (via Firebase Console)
      allow create, delete: if false;
    }
  }
}