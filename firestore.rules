/**
 * Simplified HoneyNotes Firestore Security Rules
 * 
 * Data Structure (simplified):
 * - /letters/{letterId}: All letters in one collection
 * - /users/{userId}: User profiles
 * - /tasks/{taskId}: Global task definitions
 *
 * Key Security:
 * - Letters: sender can write, sender OR recipient can read
 * - Users: only owner can read/write their profile
 * - Tasks: public read, admin write only
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Verifies ownership for an existing document. Used for update and
     * delete operations to prevent acting on non-existent data.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Basic validation for letter documents on create.
     */
    function isValidLetter() {
      return request.resource.data.keys().hasAll(['senderId','recipientId','content','config','status'])
        && request.resource.data.senderId is string
        && request.resource.data.recipientId is string
        && request.resource.data.content is string
        && request.resource.data.status in ['draft','sent','opened'];
    }

    /**
     * Validate allowed values for the `config` object (paperColor, stamp, font, borderStyle).
     */
    function isValidLetterConfig() {
      let cfg = request.resource.data.config;
      return cfg is map
        && cfg.keys().hasAny(['paperColor','stamp','font'])
        && (cfg.paperColor is string ? cfg.paperColor in ['cream','pink','crimson','honey','light-pink','lavender','mint','peach','sky','rose'] : true)
        && (cfg.stamp is string ? cfg.stamp in ['heart','bee','wax-seal','rose-emoji','star-emoji','kiss-emoji','sparkle-emoji','sun-emoji','moon-emoji'] : true)
        && (cfg.font is string ? cfg.font in ['Indie_Flower','Belleza','Dancing_Script','Pacifico','Caveat','Sacramento','Great_Vibes','Shadows_Into_Light','Amatic_SC','Permanent_Marker','Satisfy','Kalam'] : true);
    }

    /**
     * @description Rules for a user's own profile document.
     * @path /users/{userId}
     * @allow (create) An authenticated user can create their own profile document.
     * @deny  (get) A user cannot read another user's profile.
     * @principle Restricts access to a user's own data tree and prevents user enumeration.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    /**
     * Global tasks (read-only for clients)
     * /tasks/{taskId}
     */
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if false; // Admin only via console
    }
  }
}