/**
 * Simplified HoneyNotes Firestore Security Rules
 * 
 * Data Structure (simplified):
 * - /letters/{letterId}: All letters in one collection
 * - /users/{userId}: User profiles
 * - /tasks/{taskId}: Global task definitions
 *
 * Key Security:
 * - Letters: sender can write, sender OR recipient can read
 * - Users: only owner can read/write their profile
 * - Tasks: public read, admin write only
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Letters collection - simplified at root level
     * /letters/{letterId}
     * 
     * DEVELOPMENT MODE: Permitir todo para depuración
     */
    match /letters/{letterId} {
      // Permitir todo para usuarios autenticados durante desarrollo
      allow read, write: if isSignedIn();
    }

    /**
     * User profiles
     * /users/{userId}
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    /**
     * Global tasks (read-only for clients)
     * /tasks/{taskId}
     */
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if false; // Admin only via console
    }
  }
}