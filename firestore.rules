/**
 * Simplified HoneyNotes Firestore Security Rules
 * 
 * Data Structure (simplified):
 * - /letters/{letterId}: All letters in one collection
 * - /users/{userId}: User profiles
 * - /tasks/{taskId}: Global task definitions
 *
 * Key Security:
 * - Letters: sender can write, sender OR recipient can read
 * - Users: only owner can read/write their profile
 * - Tasks: public read, admin write only
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Letters collection - simplified at root level
     * /letters/{letterId}
     */
    match /letters/{letterId} {
      // Anyone signed in can read a letter if they are sender OR recipient
      allow read: if isSignedIn() 
        && (resource.data.senderId == request.auth.uid 
            || resource.data.recipientId == request.auth.uid);
      
      // Only signed-in users can create, and senderId must match their uid
      allow create: if isSignedIn() 
        && request.resource.data.senderId == request.auth.uid;
      
      // Only sender can update/delete their own letters
      allow update, delete: if isSignedIn() 
        && resource.data.senderId == request.auth.uid;
    }

    /**
     * User profiles
     * /users/{userId}
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    /**
     * Global tasks (read-only for clients)
     * /tasks/{taskId}
     */
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if false; // Admin only via console
    }
  }
}